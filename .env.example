# Real-Debrid API Key (required)
# Get from: https://real-debrid.com/apitoken
RD_API_KEY=your_api_key_here

# External URL where this server is accessible (required)
# Used for generating stream URLs in Stremio
EXTERNAL_URL=https://debroxy.example.com

# Proxy authentication token (optional but recommended)
# If not set, authentication is DISABLED (simpler but less secure)
# Must be at least 32 characters for security
# Generate a secure token: openssl rand -hex 32
PROXY_TOKEN=your_secure_token_here

# Server port (default: 8888)
PORT=8888

# Maximum concurrent streams (default: 3)
# RD allows limited concurrent downloads
MAX_CONCURRENT_STREAMS=3

# Minimum stream quality filter (optional)
# Only streams at or above this quality will be shown
# Options: 2160p, 1440p, 1080p, 720p, 480p, 360p
# MIN_STREAM_QUALITY=1080p

# SQLite database path (default: ./data/debroxy.db)
DB_PATH=./data/debroxy.db

# Library sync interval in minutes (default: 15)
SYNC_INTERVAL_MIN=15

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Transcoding settings (default: enabled)
# Uses Real-Debrid's HLS transcoding for better Stremio compatibility
TRANSCODING_ENABLED=true

# Prefer HLS transcoding over direct streams (default: true)
TRANSCODING_PREFER_HLS=true

# Transcoding cache TTL in seconds (default: 3600)
# How long to cache transcoding URLs before refreshing
# Note: This is currently not used (hardcoded to 1 hour)
TRANSCODING_CACHE_TTL=3600

# Watch completion threshold (default: 0.90)
# Percentage (0.5-0.99) at which items are marked as "completed"
WATCH_COMPLETION_THRESHOLD=0.90

# Trusted proxy IPs for correct client IP detection (default: 127.0.0.1,::1)
# Set this to your reverse proxy's IP address(es), comma-separated
# TRUSTED_PROXIES=127.0.0.1,::1

# Enable Prometheus metrics endpoint (default: true)
# ENABLE_METRICS=true

# Node environment (optional)
# Set to 'production' to enforce HTTPS for EXTERNAL_URL
# NODE_ENV=production
